<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'query.title'|trans }} — Altered Core</title>
    <script>
        // Apply saved theme before paint
        if (localStorage.theme === 'light' || (!('theme' in localStorage) && !window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/gh/PolluxTroy0/Altered-Card-Renderer@main/altered-card-renderer.js"
            data-proxy="false"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <style>
        /* Tom Select — light */
        .ts-wrapper .ts-control {
            background: rgb(249 250 251);
            border: 1px solid rgb(209 213 219);
            border-radius: 0.25rem;
            padding: 0.25rem 0.375rem;
            min-height: unset;
            font-size: 0.75rem;
            box-shadow: none;
            gap: 0.25rem;
            flex-wrap: wrap;
        }
        .ts-wrapper.focus .ts-control { border-color: rgb(96 165 250); box-shadow: none; }
        .ts-wrapper .ts-control .item {
            background: rgb(219 234 254);
            color: rgb(29 78 216);
            border: none;
            border-radius: 9999px;
            padding: 0 0.5rem;
            font-size: 0.65rem;
            font-weight: 600;
        }
        .ts-wrapper .ts-control input { font-size: 0.75rem; }
        .ts-dropdown { font-size: 0.75rem; border-color: rgb(209 213 219); border-radius: 0.25rem; z-index: 9999; }
        .ts-dropdown .option { padding: 0.375rem 0.5rem; }
        .ts-dropdown .option.active { background: rgb(239 246 255); color: rgb(29 78 216); }
        /* Tom Select — dark */
        .dark .ts-wrapper .ts-control {
            background: rgb(55 65 81);
            border-color: rgb(75 85 99);
            color: rgb(255 255 255);
        }
        .dark .ts-wrapper .ts-control .item {
            background: rgb(30 58 138);
            color: rgb(147 197 253);
        }
        .dark .ts-wrapper .ts-control input { color: rgb(255 255 255); }
        .dark .ts-wrapper .ts-control input::placeholder { color: rgb(156 163 175); }
        .dark .ts-dropdown {
            background: rgb(31 41 55);
            border-color: rgb(75 85 99);
            color: rgb(209 213 219);
        }
        .dark .ts-dropdown .option.active { background: rgb(30 58 138); color: rgb(147 197 253); }
        .ts-wrapper .ts-control .remove { color: inherit; opacity: 0.6; margin-left: 0.25rem; }
        .stat-chip { cursor: pointer; user-select: none; }
        .stat-chip.chip-active { background-color: rgb(59 130 246) !important; color: #fff !important; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 antialiased text-sm">

<nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 fixed w-full z-30 top-0">
    <div class="px-4 py-3 lg:px-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="text-xl font-bold text-gray-900 dark:text-white">Altered Core</span>
            <span class="text-gray-400">/</span>
            <span class="text-sm text-gray-500 dark:text-gray-400">{{ 'query.title'|trans }}</span>
        </div>
        <div class="flex items-center gap-3">
            {# Locale switcher #}
            <div class="flex items-center gap-1 text-xs">
                <a href="{{ path('switch_locale', {locale: 'fr'}) }}"
                   class="px-1.5 py-0.5 rounded font-medium {{ app.request.locale == 'fr' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' : 'text-gray-400 hover:text-gray-700 dark:hover:text-gray-200' }}">
                    FR
                </a>
                <span class="text-gray-300 dark:text-gray-600">/</span>
                <a href="{{ path('switch_locale', {locale: 'en'}) }}"
                   class="px-1.5 py-0.5 rounded font-medium {{ app.request.locale == 'en' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' : 'text-gray-400 hover:text-gray-700 dark:hover:text-gray-200' }}">
                    EN
                </a>
            </div>
            <button id="theme-toggle" class="p-2 rounded text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
            <svg id="icon-sun" class="hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
            </svg>
            <svg id="icon-moon" class="hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
        </button>
        </div>{# end flex items-center gap-3 #}
    </div>
</nav>

<div class="pt-16 px-4 py-6 lg:px-8">
<div class="flex gap-4 items-start">

    {# ── Left: filters ────────────────────────────────────────────────────── #}
    <div class="w-2/5 space-y-3" id="query-form">

        {# Identité & Groupe #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ 'query.section.identity'|trans }}</h3>
            <div class="grid grid-cols-2 gap-2">
                {# Name search — full width #}
                <div class="col-span-2">
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.name'|trans }}</label>
                    <input type="text" id="name-search"
                           class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5"
                           placeholder="{{ 'query.placeholder.name_search'|trans }}">
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.reference'|trans }}</label>
                    <input type="text" data-param="reference"
                           class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5"
                           placeholder="ALT_CORE_B_AX_04_C">
                </div>
                <div class="col-span-2">
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.reference'|trans }} (liste, max 200)</label>
                    <textarea id="ref-list" rows="3"
                              class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5 font-mono resize-y"
                              placeholder="ALT_CORE_B_AX_04_C&#10;ALT_CORE_B_AX_05_R_1&#10;…"></textarea>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.set'|trans }}</label>
                    <select data-param="set.reference" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_m'|trans }}</option>
                        {% for set in sets %}
                            <option value="{{ set.reference }}">{{ set.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.faction'|trans }}</label>
                    <select data-param="faction.code" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_f'|trans }}</option>
                        {% for faction in factions %}
                            <option value="{{ faction.code }}">{{ faction.name }} ({{ faction.code }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.rarity'|trans }}</label>
                    <select data-param="rarity" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_f'|trans }}</option>
                        {% for rarity in rarities %}
                            <option value="{{ rarity.reference }}">{{ rarity.name.fr ?? rarity.reference }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.type'|trans }}</label>
                    <select data-param="cardType" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_m'|trans }}</option>
                        {% for type in cardTypes %}
                            <option value="{{ type.reference }}">{{ type.name.fr ?? type.reference }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.subtype'|trans }}</label>
                    <select data-param="subTypes" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_m'|trans }}</option>
                        {% for sub in subTypes %}
                            <option value="{{ sub.reference }}">{{ sub.name.fr ?? sub.reference }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.variation'|trans }}</label>
                    <select data-param="variation" multiple
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.all_f'|trans }}</option>
                        <option value="standard">{{ 'query.option.standard'|trans }}</option>
                        <option value="alt-art">Alt-art</option>
                        <option value="promo">Promo</option>
                        <option value="kickstarter">Kickstarter</option>
                        <option value="serialized">Serialized</option>
                    </select>
                </div>
            </div>
        </div>

        {# Coûts & Puissances #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ 'query.section.costs'|trans }}</h3>
            <div class="grid grid-cols-5 gap-2">
                {% for label, param in {
                    ('query.label.main_cost'|trans):   'mainCost',
                    ('query.label.recall_cost'|trans): 'recallCost',
                    ('query.label.ocean'|trans):       'oceanPower',
                    ('query.label.mountain'|trans):    'mountainPower',
                    ('query.label.forest'|trans):      'forestPower',
                } %}
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ label }}</label>
                    <div class="flex gap-1 mb-1">
                        <select data-stat-op="{{ param }}"
                                class="stat-op w-12 bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1 shrink-0">
                            <option value="exact">=</option>
                            <option value="gte">≥</option>
                            <option value="gt">&gt;</option>
                            <option value="lte">≤</option>
                            <option value="lt">&lt;</option>
                        </select>
                        <input type="number" min="0" max="12" data-stat-val="{{ param }}"
                               class="stat-val min-w-0 w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5"
                               placeholder="—">
                    </div>
                    <div class="flex flex-wrap gap-0.5">
                        {% for i in 0..12 %}
                        <button type="button"
                                data-stat-chip="{{ param }}" data-val="{{ i }}"
                                class="stat-chip min-w-[1.15rem] h-[1.15rem] px-0.5 text-[0.6rem] leading-none rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 hover:bg-blue-100 dark:hover:bg-blue-900 font-medium transition-colors">{{ i }}</button>
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Effets — slots #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ 'query.section.effects'|trans }}</h3>
            <div class="space-y-3">

                {# Effect slots builder #}
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label class="text-xs text-gray-600 dark:text-gray-400">{{ 'query.label.effect_slots'|trans }}</label>
                        <div class="flex items-center gap-3 text-xs text-gray-600 dark:text-gray-400">
                            <label class="flex items-center gap-1 cursor-pointer">
                                <input type="radio" name="effectSlotMode" value="or" checked class="accent-blue-600"> {{ 'query.option.or'|trans }}
                            </label>
                            <label class="flex items-center gap-1 cursor-pointer">
                                <input type="radio" name="effectSlotMode" value="and" class="accent-blue-600"> {{ 'query.option.and'|trans }}
                            </label>
                        </div>
                    </div>
                    <div id="effect-slots" class="space-y-2"></div>
                    <button type="button" id="slot-add"
                            class="mt-2 w-full py-1.5 text-xs font-medium text-blue-600 dark:text-blue-400 border border-blue-300 dark:border-blue-700 rounded hover:bg-blue-50 dark:hover:bg-blue-950">
                        {{ 'query.button.add_slot'|trans }}
                    </button>
                </div>

                {# Présence d'effets #}
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.effect_presence'|trans }}</label>
                    <select data-param="hasNoEffect"
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.any'|trans }}</option>
                        <option value="false">{{ 'query.option.at_least_1_effect'|trans }}</option>
                        <option value="true">{{ 'query.option.no_effect'|trans }}</option>
                    </select>
                </div>

                {# Triggers identiques #}
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.same_trigger'|trans }}</label>
                    <select data-param="minSameTriggerCount"
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.placeholder.any'|trans }}</option>
                        <option value="2">{{ 'query.option.min_2_same'|trans }}</option>
                        <option value="3">{{ 'query.option.all_3_same'|trans }}</option>
                    </select>
                </div>

                {# Keywords multi #}
                <div>
                    <div class="flex items-center justify-between mb-1">
                        <label class="text-xs text-gray-600 dark:text-gray-400">{{ 'query.label.keywords'|trans }}</label>
                        <div class="flex items-center gap-3 text-xs text-gray-600 dark:text-gray-400">
                            <label class="flex items-center gap-1 cursor-pointer">
                                <input type="radio" name="kwMode" value="or" checked class="accent-blue-600"> {{ 'query.option.or'|trans }}
                            </label>
                            <label class="flex items-center gap-1 cursor-pointer">
                                <input type="radio" name="kwMode" value="and" class="accent-blue-600"> {{ 'query.option.and'|trans }}
                            </label>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <input type="text" id="kw-input"
                               class="flex-1 bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5 uppercase"
                               placeholder="ex: CORIACE, FUGACE…">
                        <button type="button" id="kw-add"
                                class="px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded hover:bg-blue-700">+</button>
                    </div>
                    <div id="kw-tags" class="flex flex-wrap gap-1 mt-2 min-h-[1.5rem]"></div>
                </div>

            </div>
        </div>

        {# Statut #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ 'query.section.status'|trans }}</h3>
            <div class="grid grid-cols-3 gap-2">
                {% for label, param in {
                    ('query.label.banned'|trans):      'isBanned',
                    ('query.label.suspended'|trans):   'isSuspended',
                    ('query.label.errated'|trans):     'isErrated',
                    ('query.label.serialized'|trans):  'isSerialized',
                    ('query.label.kickstarter'|trans): 'kickstarter',
                    ('query.label.promo'|trans):       'promo',
                } %}
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ label }}</label>
                    <select data-param="{{ param }}"
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">{{ 'query.option.indiff'|trans }}</option>
                        <option value="true">{{ 'query.option.yes'|trans }}</option>
                        <option value="false">{{ 'query.option.no'|trans }}</option>
                    </select>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Pagination & Tri #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ 'query.section.pagination'|trans }}</h3>
            <div class="grid grid-cols-3 gap-2">
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.page'|trans }}</label>
                    <input type="number" min="1" data-param="page"
                           class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.per_page'|trans }}</label>
                    <select data-param="itemsPerPage"
                            class="qb-input w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="50">50</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                        <option value="1000">1000</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">{{ 'query.label.sort'|trans }}</label>
                    <select id="sort-select"
                            class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5">
                        <option value="">—</option>
                        <option value="cardNumber:asc">N° ↑</option>
                        <option value="cardNumber:desc">N° ↓</option>
                        <option value="random:asc">Random</option>
                        <option value="mainCost:asc">{{ 'query.label.main_cost'|trans }} ↑</option>
                        <option value="mainCost:desc">{{ 'query.label.main_cost'|trans }} ↓</option>
                        <option value="recallCost:asc">{{ 'query.label.recall_cost'|trans }} ↑</option>
                        <option value="recallCost:desc">{{ 'query.label.recall_cost'|trans }} ↓</option>
                        <option value="oceanPower:asc">{{ 'query.label.ocean'|trans }} ↑</option>
                        <option value="oceanPower:desc">{{ 'query.label.ocean'|trans }} ↓</option>
                        <option value="mountainPower:asc">{{ 'query.label.mountain'|trans }} ↑</option>
                        <option value="mountainPower:desc">{{ 'query.label.mountain'|trans }} ↓</option>
                        <option value="forestPower:asc">{{ 'query.label.forest'|trans }} ↑</option>
                        <option value="forestPower:desc">{{ 'query.label.forest'|trans }} ↓</option>
                    </select>
                </div>
            </div>
        </div>

    </div>

    {# ── Right: URL + results ─────────────────────────────────────────────── #}
    <div class="w-3/5 space-y-3">

        {# URL preview #}
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">{{ 'query.result.url_label'|trans }}</span>
                <div class="flex gap-3">
                    <button id="btn-copy" class="text-xs text-blue-600 hover:text-blue-800 font-medium">{{ 'query.button.copy'|trans }}</button>
                    <a id="btn-open" href="/api/cards" target="_blank"
                       class="text-xs text-gray-400 hover:text-gray-600">{{ 'query.button.open'|trans }}</a>
                </div>
            </div>
            <code id="url-preview"
                  class="block text-xs text-gray-700 dark:text-gray-300 break-all font-mono bg-gray-50 dark:bg-gray-900 rounded p-2 whitespace-pre-wrap">/api/cards</code>
        </div>

        {# Actions #}
        <div class="flex gap-2">
            <button id="btn-run"
                    class="flex-1 px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700">
                {{ 'query.button.search'|trans }}
            </button>
            <button id="btn-reset"
                    class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 rounded-lg border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">
                {{ 'query.button.reset'|trans }}
            </button>
        </div>

        {# Results #}
        <div id="results-box" class="hidden bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">

            <div class="flex items-center justify-between px-3 py-2 border-b border-gray-200 dark:border-gray-700">
                <span id="results-count" class="text-xs font-semibold text-gray-900 dark:text-white"></span>
                <div class="flex items-center gap-1">
                    <button id="view-list" title="{{ 'query.result.view_list'|trans }}"
                            class="view-btn p-1.5 rounded text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 bg-gray-100 dark:bg-gray-700">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                        </svg>
                    </button>
                    <button id="view-grid" title="{{ 'query.result.view_grid'|trans }}"
                            class="view-btn p-1.5 rounded text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                    </button>
                    <button id="view-render" title="Render"
                            class="view-btn p-1.5 rounded text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div id="results-loading" class="hidden text-sm text-gray-400 text-center py-6">{{ 'query.result.loading'|trans }}</div>
            <div id="results-error" class="hidden text-sm text-red-500 px-3 py-2"></div>

            {# List view #}
            <div id="view-list-panel" class="overflow-x-auto">
                <table class="w-full text-xs text-left">
                    <thead id="results-head" class="hidden bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400 uppercase">
                        <tr>
                            <th class="px-3 py-2">{{ 'query.result.col_ref'|trans }}</th>
                            <th class="px-3 py-2">{{ 'query.result.col_name'|trans }}</th>
                            <th class="px-3 py-2">{{ 'query.result.col_faction'|trans }}</th>
                            <th class="px-3 py-2">{{ 'query.result.col_rarity'|trans }}</th>
                            <th class="px-3 py-2">{{ 'query.result.col_cost'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody id="results-list" class="divide-y divide-gray-100 dark:divide-gray-700"></tbody>
                </table>
            </div>

            {# Grid view #}
            <div id="view-grid-panel" class="hidden p-3">
                <div id="results-grid" class="grid grid-cols-5 gap-3"></div>
            </div>

            {# Render view #}
            <div id="view-render-panel" class="hidden p-3">
                <div id="results-render" class="grid grid-cols-5 gap-2"></div>
            </div>

            {% if app.debug %}
            {# Debug panel — dev only #}
            <div id="debug-panel" class="hidden border-t border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-950/30 px-3 py-2">
                <div class="flex items-center gap-2 mb-1.5">
                    <span class="text-xs font-bold text-yellow-700 dark:text-yellow-400 uppercase tracking-wide">Debug</span>
                    <span id="debug-total" class="text-xs text-yellow-600 dark:text-yellow-500"></span>
                </div>
                <table class="w-full text-xs text-left">
                    <thead>
                        <tr class="text-yellow-600 dark:text-yellow-500">
                            <th class="pr-4 font-medium">Filter</th>
                            <th class="pr-4 font-medium">Path</th>
                            <th class="pr-4 font-medium">Duration</th>
                            <th class="font-medium">IDs pre-selected</th>
                        </tr>
                    </thead>
                    <tbody id="debug-rows" class="text-yellow-800 dark:text-yellow-300"></tbody>
                </table>
            </div>
            {% endif %}

            {# Pagination #}
            <div id="results-pagination" class="hidden flex items-center justify-between px-3 py-2 border-t border-gray-200 dark:border-gray-700">
                <button id="page-prev"
                        class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">
                    {{ 'query.result.prev'|trans }}
                </button>
                <span id="page-info" class="text-xs text-gray-500 dark:text-gray-400"></span>
                <button id="page-next"
                        class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">
                    {{ 'query.result.next'|trans }}
                </button>
            </div>

        </div>

    </div>
</div>
</div>

{# Lightbox modal — must be in DOM before the script block runs #}
<div id="lightbox"
     class="fixed inset-0 z-50 hidden bg-black/85 flex items-center justify-center p-4">
    <img id="lightbox-img" src="" alt=""
         class="max-w-full max-h-full object-contain rounded shadow-2xl select-none">
    <button id="lightbox-close"
            class="absolute top-4 right-4 text-white/70 hover:text-white text-3xl leading-none">&times;</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2/dist/js/tom-select.complete.min.js"></script>
<script>
(function () {
    const BASE = '/api/cards';

    // Server-side translations injected by Twig
    // ── Display locale (from session, set via nav FR/EN switcher) ───────────
    const displayLocale = '{{ app.request.locale }}';

    function cardName(card) {
        const langs = displayLocale === 'en'
            ? [card.name?.en, card.name?.fr]
            : [card.name?.fr, card.name?.en];
        return langs.find(v => v) ?? '—';
    }

    const T = {
        no_results:           {{ 'query.result.no_results'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        loading:              {{ 'query.result.loading'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        copied:               {{ 'query.button.copied'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        copy:                 {{ 'query.button.copy'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        results_count:        {{ 'query.result.results_count'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        error_network:        {{ 'query.result.error_network'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        error_http:           {{ 'query.result.error_http'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        effect_search_ph:     {{ 'query.result.effect_search_placeholder'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
        page_info:            {{ 'query.result.page_info'|trans|json_encode(constant('JSON_HEX_TAG'))|raw }},
    };
    let keywords    = [];
    let effectSlots = [];   // [{trigger, condition, effect, effectLabel}]
    let viewMode    = 'list';
    let currentPage = 1;
    let totalItems  = 0;
    let perPage     = 30;
    let lastMembers = [];

    // ── Theme toggle ────────────────────────────────────────────────────────
    const html      = document.documentElement;
    const iconSun   = document.getElementById('icon-sun');
    const iconMoon  = document.getElementById('icon-moon');

    function applyTheme() {
        const dark = html.classList.contains('dark');
        iconSun.classList.toggle('hidden', !dark);
        iconMoon.classList.toggle('hidden', dark);
    }
    applyTheme();

    document.getElementById('theme-toggle').addEventListener('click', () => {
        html.classList.toggle('dark');
        localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
        applyTheme();
    });

    // ── Trigger / condition data (server-rendered) ──────────────────────────
    const TRIGGERS = [
        {% for t in triggers %}
        { id: {{ t.id }}, label: {{ (t.textFr ?? t.textEn ?? t.id ~ '')|json_encode(constant('JSON_HEX_TAG'))|raw }} },
        {% endfor %}
    ];

    const CONDITIONS = [
        {% for c in conditions %}
        { id: {{ c.id }}, label: {{ (c.textFr ?? c.textEn ?? c.id ~ '')|json_encode(constant('JSON_HEX_TAG'))|raw }} },
        {% endfor %}
    ];

    // ── Effect slot builder ─────────────────────────────────────────────────
    function buildSelectHtml(items, placeholder) {
        let html = `<option value="">${placeholder}</option>`;
        items.forEach(({ id, label }) => {
            const display = label ? label.substring(0, 60) : String(id);
            html += `<option value="${id}">${display}</option>`;
        });
        return html;
    }

    const SEL = 'w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5';
    const INP = 'flex-1 bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-xs rounded p-1.5';

    function renderEffectSlots() {
        const container = document.getElementById('effect-slots');
        container.innerHTML = '';

        effectSlots.forEach((slot, idx) => {
            const row = document.createElement('div');
            row.className = 'relative flex gap-1.5 items-start p-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded';
            row.dataset.idx = idx;

            row.innerHTML = `
                <div class="flex-1 space-y-1.5">
                    <div class="flex gap-1.5">
                        <select class="slot-trigger ${SEL}" data-idx="${idx}">
                            ${buildSelectHtml(TRIGGERS, '— trigger —')}
                        </select>
                        <select class="slot-condition ${SEL}" data-idx="${idx}">
                            ${buildSelectHtml(CONDITIONS, '— condition —')}
                        </select>
                    </div>
                    <div class="relative flex gap-1.5 items-center">
                        <input type="text" class="slot-effect-search ${INP}" data-idx="${idx}"
                               placeholder="${T.effect_search_ph}" autocomplete="off">
                        <button type="button" class="slot-effect-clear hidden text-xs text-gray-400 hover:text-red-500 px-1 shrink-0" data-idx="${idx}" title="Effacer">✕</button>
                        <div class="slot-effect-results hidden absolute left-0 top-full mt-1 z-20 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded shadow-lg text-xs max-h-48 overflow-y-auto w-full" data-idx="${idx}"></div>
                    </div>
                </div>
                <button type="button" class="slot-remove shrink-0 mt-1 text-gray-300 hover:text-red-500 text-sm font-bold leading-none" data-idx="${idx}" title="Supprimer">×</button>
            `;

            container.appendChild(row);

            // Restore values
            const triggerSel   = row.querySelector('.slot-trigger');
            const conditionSel = row.querySelector('.slot-condition');
            const searchInput  = row.querySelector('.slot-effect-search');
            const clearBtn     = row.querySelector('.slot-effect-clear');

            if (slot.trigger)   triggerSel.value   = slot.trigger;
            if (slot.condition) conditionSel.value  = slot.condition;
            if (slot.effect && slot.effectLabel) {
                searchInput.value    = slot.effectLabel;
                searchInput.readOnly = true;
                clearBtn.classList.remove('hidden');
            }

            triggerSel.addEventListener('change', e => {
                effectSlots[idx].trigger = e.target.value ? +e.target.value : '';
                updatePreview();
            });
            conditionSel.addEventListener('change', e => {
                effectSlots[idx].condition = e.target.value ? +e.target.value : '';
                updatePreview();
            });

            bindEffectSearch(row, idx);

            row.querySelector('.slot-remove').addEventListener('click', () => {
                effectSlots.splice(idx, 1);
                renderEffectSlots();
                updatePreview();
            });
        });
    }

    function bindEffectSearch(row, idx) {
        const searchInput = row.querySelector('.slot-effect-search');
        const resultsDiv  = row.querySelector('.slot-effect-results');
        const clearBtn    = row.querySelector('.slot-effect-clear');
        let timer = null;

        searchInput.addEventListener('input', () => {
            clearTimeout(timer);
            const q = searchInput.value.trim();
            if (q.length < 2) { resultsDiv.classList.add('hidden'); return; }
            timer = setTimeout(() => fetchEffects(q, resultsDiv, idx, searchInput, clearBtn), 250);
        });

        document.addEventListener('click', e => {
            if (!row.contains(e.target)) resultsDiv.classList.add('hidden');
        });

        clearBtn.addEventListener('click', () => {
            effectSlots[idx].effect      = '';
            effectSlots[idx].effectLabel = '';
            searchInput.value    = '';
            searchInput.readOnly = false;
            clearBtn.classList.add('hidden');
            resultsDiv.innerHTML = '';
            resultsDiv.classList.add('hidden');
            updatePreview();
        });
    }

    async function fetchEffects(q, resultsDiv, idx, searchInput, clearBtn) {
        try {
            const langParam = displayLocale === 'en' ? 'textEn' : 'textFr';
            const resp = await fetch(`/api/ability_effects?${langParam}=${encodeURIComponent(q)}&itemsPerPage=20`, {
                headers: { Accept: 'application/json' }
            });
            const data  = await resp.json();
            const items = data['hydra:member'] ?? [];

            resultsDiv.innerHTML = '';
            if (items.length === 0) {
                resultsDiv.innerHTML = `<div class="px-3 py-2 text-gray-400">${T.no_results}</div>`;
            } else {
                items.forEach(item => {
                    const label = (displayLocale === 'en' ? item.text?.en : item.text?.fr) ?? item.text?.fr ?? item.text?.en ?? String(item.id);
                    const div   = document.createElement('div');
                    div.className = 'px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-950 cursor-pointer border-b border-gray-100 dark:border-gray-700 last:border-0 text-gray-900 dark:text-gray-200';
                    div.textContent = label.length > 100 ? label.substring(0, 100) + '…' : label;
                    div.title = label;
                    div.addEventListener('click', () => {
                        const short = label.length > 70 ? label.substring(0, 70) + '…' : label;
                        effectSlots[idx].effect      = item.id;
                        effectSlots[idx].effectLabel = short;
                        searchInput.value    = short;
                        searchInput.readOnly = true;
                        clearBtn.classList.remove('hidden');
                        resultsDiv.classList.add('hidden');
                        updatePreview();
                    });
                    resultsDiv.appendChild(div);
                });
            }
            resultsDiv.classList.remove('hidden');
        } catch (e) {
            console.error('Effect search error', e);
        }
    }

    document.getElementById('slot-add').addEventListener('click', () => {
        effectSlots.push({ trigger: '', condition: '', effect: '', effectLabel: '' });
        renderEffectSlots();
        updatePreview();
    });

    document.querySelectorAll('input[name="effectSlotMode"]').forEach(r =>
        r.addEventListener('change', updatePreview)
    );

    // ── URL builder ─────────────────────────────────────────────────────────
    function buildParams(page) {
        const params = new URLSearchParams();

        // Name search (uses session locale)
        const nameVal = (document.getElementById('name-search')?.value ?? '').trim();
        if (nameVal) params.set(`name[${displayLocale}]`, nameVal);

        // Reference list goes via POST batch — not added to GET params

        document.querySelectorAll('.qb-input').forEach(el => {
            const param = el.dataset.param;
            if (!param || param === 'page') return;
            if (el.multiple) {
                Array.from(el.querySelectorAll('option:checked'))
                    .map(o => o.value)
                    .filter(Boolean)
                    .forEach(v => params.append(param + '[]', v));
            } else {
                const val = (el.value ?? '').trim();
                if (val !== '') params.set(param, val);
            }
        });

        // Stat fields — chips (IN) take priority over range operator+value
        const handledByChips = new Set();
        document.querySelectorAll('.stat-chip.chip-active').forEach(chip => {
            const param = chip.dataset.statChip;
            if (!param) return;
            params.append(`${param}[]`, chip.dataset.val);
            handledByChips.add(param);
        });

        document.querySelectorAll('.stat-val').forEach(el => {
            const param = el.dataset.statVal;
            if (!param || handledByChips.has(param)) return;
            const val = (el.value ?? '').trim();
            if (val === '') return;
            const opEl = document.querySelector(`.stat-op[data-stat-op="${param}"]`);
            const op   = opEl?.value ?? 'exact';
            if (op === 'exact') {
                params.set(param, val);
            } else {
                params.set(`${param}[${op}]`, val);
            }
        });

        // Sort
        const sortVal = (document.getElementById('sort-select')?.value ?? '').trim();
        if (sortVal) {
            const sep = sortVal.lastIndexOf(':');
            const field = sortVal.slice(0, sep);
            const dir   = sortVal.slice(sep + 1);
            if (field === 'random') {
                params.set('random', 'true');
            } else {
                params.set(`order[${field}]`, dir);
            }
        }

        // Effect slots
        let slotIdx = 0;
        effectSlots.forEach(slot => {
            if (!slot.trigger && !slot.condition && !slot.effect) return;
            if (slot.trigger)   params.set(`effectSlot[${slotIdx}][trigger]`,   slot.trigger);
            if (slot.condition) params.set(`effectSlot[${slotIdx}][condition]`,  slot.condition);
            if (slot.effect)    params.set(`effectSlot[${slotIdx}][effect]`,     slot.effect);
            slotIdx++;
        });
        if (slotIdx > 1) {
            const mode = document.querySelector('input[name="effectSlotMode"]:checked')?.value ?? 'or';
            params.set('effectSlotMode', mode);
        }

        // Keywords
        if (keywords.length > 0) {
            keywords.forEach(kw => params.append('effectKeyword[]', kw));
            if (keywords.length > 1) {
                const mode = document.querySelector('input[name="kwMode"]:checked')?.value ?? 'or';
                params.set('effectKeywordMode', mode);
            }
        }

        const p = page ?? currentPage;
        if (p > 1) params.set('page', p);
        return params;
    }

    function buildUrl(page) {
        const qs = buildParams(page).toString();
        return qs ? BASE + '?' + decodeURIComponent(qs) : BASE;
    }

    function updatePreview() {
        const url = buildUrl();
        document.getElementById('url-preview').textContent = url;
        document.getElementById('btn-open').href = url;
    }

    document.querySelectorAll('.qb-input').forEach(el => {
        el.addEventListener('input', updatePreview);
        el.addEventListener('change', updatePreview);
    });

    document.querySelectorAll('.stat-val, .stat-op').forEach(el => {
        el.addEventListener('input', updatePreview);
        el.addEventListener('change', updatePreview);
    });

    document.querySelectorAll('.stat-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            chip.classList.toggle('chip-active');
            updatePreview();
        });
    });

    document.getElementById('sort-select')?.addEventListener('change', updatePreview);

    // ── Keywords ────────────────────────────────────────────────────────────
    function renderTags() {
        const container = document.getElementById('kw-tags');
        container.innerHTML = '';
        keywords.forEach((kw, i) => {
            const chip = document.createElement('span');
            chip.className = 'inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900 dark:text-teal-300';
            chip.innerHTML = `${kw} <button type="button" data-i="${i}" class="kw-remove text-teal-600 hover:text-red-600 font-bold">&times;</button>`;
            container.appendChild(chip);
        });
        container.querySelectorAll('.kw-remove').forEach(btn => {
            btn.addEventListener('click', () => {
                keywords.splice(+btn.dataset.i, 1);
                renderTags();
            });
        });
        updatePreview();
    }

    function addKeyword(raw) {
        raw.split(/[,\s]+/).map(s => s.trim().toUpperCase()).filter(Boolean).forEach(kw => {
            if (kw && !keywords.includes(kw)) keywords.push(kw);
        });
        document.getElementById('kw-input').value = '';
        renderTags();
    }

    document.getElementById('kw-add').addEventListener('click', () =>
        addKeyword(document.getElementById('kw-input').value)
    );
    document.getElementById('kw-input').addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); addKeyword(e.target.value); }
    });
    document.querySelectorAll('input[name="kwMode"]').forEach(r =>
        r.addEventListener('change', updatePreview)
    );

    // ── View mode ───────────────────────────────────────────────────────────
    const RARITY_COLORS = {
        COMMON:  'bg-gray-400 text-white',
        RARE:    'bg-blue-500 text-white',
        UNIQUE:  'bg-yellow-400 text-gray-900',
        EXALTED: 'bg-pink-500 text-white',
    };

    const FACTION_COLORS = {
        BR: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300',
        AX: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300',
        LY: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300',
        MU: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300',
        OR: 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300',
        YZ: 'bg-pink-100 text-pink-800 dark:bg-pink-900 dark:text-pink-300',
    };

    function setViewMode(mode) {
        viewMode = mode;
        document.getElementById('view-list-panel').classList.toggle('hidden', mode !== 'list');
        document.getElementById('view-grid-panel').classList.toggle('hidden', mode !== 'grid');
        document.getElementById('view-render-panel').classList.toggle('hidden', mode !== 'render');
        ['list', 'grid', 'render'].forEach(m => {
            const btn = document.getElementById('view-' + m);
            if (!btn) return;
            btn.classList.toggle('bg-gray-100', mode === m);
            btn.classList.toggle('dark:bg-gray-700', mode === m);
        });
        if (mode === 'render') renderAlteredCards(lastMembers);
    }
    document.getElementById('view-list').addEventListener('click', () => setViewMode('list'));
    document.getElementById('view-grid').addEventListener('click', () => setViewMode('grid'));
    document.getElementById('view-render').addEventListener('click', () => setViewMode('render'));

    // ── Render ──────────────────────────────────────────────────────────────
    function renderListRows(members) {
        const head = document.getElementById('results-head');
        const list = document.getElementById('results-list');
        list.innerHTML = '';
        if (members.length === 0) {
            head.classList.add('hidden');
            list.innerHTML = `<tr><td colspan="5" class="px-3 py-8 text-center text-gray-400">${T.no_results}</td></tr>`;
            return;
        }
        head.classList.remove('hidden');
        members.forEach(card => {
            const tr      = document.createElement('tr');
            tr.className  = 'hover:bg-gray-50 dark:hover:bg-gray-700';
            const ref     = card.reference ?? '—';
            const name    = cardName(card);
            const faction = card.faction?.code ?? '—';
            const rarity  = card.rarity?.reference ?? '—';
            const cost    = card.mainCost ?? '—';
            const fColor  = FACTION_COLORS[faction] ?? 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
            tr.innerHTML = `
                <td class="px-3 py-2 font-mono text-gray-400 dark:text-gray-500 text-xs">${ref}</td>
                <td class="px-3 py-2 text-gray-900 dark:text-white text-xs font-medium">${name}</td>
                <td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-xs font-semibold ${fColor}">${faction}</span></td>
                <td class="px-3 py-2 text-gray-500 dark:text-gray-400 text-xs">${rarity}</td>
                <td class="px-3 py-2 text-gray-400 dark:text-gray-500 text-xs text-center">${cost}</td>
            `;
            list.appendChild(tr);
        });
    }

    function renderGridCards(members) {
        const grid = document.getElementById('results-grid');
        grid.innerHTML = '';
        if (members.length === 0) {
            grid.innerHTML = `<p class="col-span-5 text-center text-gray-400 py-8">${T.no_results}</p>`;
            return;
        }
        members.forEach(card => {
            const ref     = card.reference ?? '—';
            const name    = cardName(card);
            const faction = card.faction?.code ?? '—';
            const rarity  = card.rarity?.reference ?? '—';
            const set     = card.set?.reference ?? '—';
            const cost    = card.mainCost ?? null;
            const fColor  = FACTION_COLORS[faction] ?? 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
            const rColor  = RARITY_COLORS[rarity] ?? 'bg-gray-400 text-white';
            const img     = card.imagePath?.fr ?? card.imagePath?.en ?? null;

            const div = document.createElement('div');
            div.className = 'rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden bg-white dark:bg-gray-800 flex flex-col';
            div.innerHTML = `
                ${img
                    ? `<img src="${img}" alt="" loading="lazy" class="w-full block cursor-zoom-in" data-lightbox="1">`
                    : `<div class="w-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-300 dark:text-gray-600 text-xs" style="height:160px">${ref}</div>`
                }
                <div class="p-2 flex flex-col gap-1">
                    <p class="text-xs font-semibold text-gray-900 dark:text-white truncate" title="${name}">${name}</p>
                    <div class="flex items-center gap-1 mt-1 flex-wrap">
                        <span class="px-1.5 py-0.5 rounded text-xs font-semibold ${fColor}">${faction}</span>
                        <span class="px-1.5 py-0.5 rounded text-xs font-semibold ${rColor}">${rarity}</span>
                        <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">${set}</span>
                    </div>
                </div>
            `;
            grid.appendChild(div);
            if (img) {
                const imgEl = div.querySelector('[data-lightbox]');
                imgEl.dataset.src  = img;
                imgEl.dataset.name = name;
            }
        });
    }

    // ── Altered card renderer ────────────────────────────────────────────────
    function renderAlteredCards(members) {
        const container = document.getElementById('results-render');
        container.innerHTML = '';
        if (!members.length) {
            container.innerHTML = `<p class="text-gray-400 text-sm py-8 w-full text-center">${T.no_results}</p>`;
            return;
        }
        const apiBase = window.location.origin;
        const apiTemplate = `${apiBase}/api/cards/reference/{ref}?locale={locale}`;
        members.forEach(card => {
            const ref = card.reference ?? null;
            if (!ref) return;
            const wrapper = document.createElement('div');
            wrapper.style.cssText = 'min-width:0;';
            const el = document.createElement('altered-card');
            el.setAttribute('ref', ref);
            el.setAttribute('api', apiTemplate);
            el.setAttribute('locale', displayLocale);
            wrapper.appendChild(el);
            container.appendChild(wrapper);
        });
    }

    // ── Pagination ──────────────────────────────────────────────────────────
    function updatePagination() {
        const pag     = document.getElementById('results-pagination');
        const info    = document.getElementById('page-info');
        const prevBtn = document.getElementById('page-prev');
        const nextBtn = document.getElementById('page-next');
        const last    = Math.ceil(totalItems / perPage);
        if (totalItems <= perPage) { pag.classList.add('hidden'); return; }
        pag.classList.remove('hidden');
        info.textContent = T.page_info.replace('%current%', currentPage).replace('%total%', last);
        prevBtn.disabled = currentPage <= 1;
        nextBtn.disabled = currentPage >= last;
    }

    function getRefList() {
        return (document.getElementById('ref-list')?.value ?? '')
            .split(/[\n,;]+/)
            .map(r => r.trim().toUpperCase())
            .filter(Boolean);
    }

    async function fetchPage(page) {
        currentPage = page;
        updatePreview();

        const loading = document.getElementById('results-loading');
        const error   = document.getElementById('results-error');
        const count   = document.getElementById('results-count');

        loading.classList.remove('hidden');
        error.classList.add('hidden');
        document.getElementById('results-list').innerHTML = '';
        document.getElementById('results-grid').innerHTML = '';

        try {
            const refs = getRefList();
            let resp, data;

            if (refs.length > 0) {
                // ── POST batch ──────────────────────────────────────────────
                resp = await fetch(BASE + '/batch', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                    body:    JSON.stringify({ references: refs }),
                });
                data = await resp.json();
            } else {
                // ── GET collection ──────────────────────────────────────────
                const qs = buildParams(page).toString();
                resp = await fetch(qs ? BASE + '?' + qs : BASE, { headers: { Accept: 'application/json' } });
                data = await resp.json();
            }

            if (!resp.ok) {
                error.classList.remove('hidden');
                error.textContent = T.error_http.replace('%status%', resp.status).replace('%detail%', data.detail ?? data['hydra:description'] ?? JSON.stringify(data));
                return;
            }

            lastMembers = data['member'] ?? (Array.isArray(data) ? data : []);
            totalItems  = data['totalItems'] ?? lastMembers.length;
            perPage     = lastMembers.length || 30;

            count.textContent = T.results_count.replace('%count%', totalItems.toLocaleString());
            renderListRows(lastMembers);
            renderGridCards(lastMembers);
            if (viewMode === 'render') renderAlteredCards(lastMembers);
            updatePagination();
            renderDebugPanel(resp);
        } catch (e) {
            error.classList.remove('hidden');
            error.textContent = T.error_network.replace('%msg%', e.message);
        } finally {
            loading.classList.add('hidden');
        }
    }

    document.getElementById('page-prev').addEventListener('click', () => fetchPage(currentPage - 1));
    document.getElementById('page-next').addEventListener('click', () => fetchPage(currentPage + 1));

    // ── Copy / Reset / Run ──────────────────────────────────────────────────
    document.getElementById('btn-copy').addEventListener('click', () => {
        navigator.clipboard.writeText(buildUrl()).then(() => {
            const btn = document.getElementById('btn-copy');
            btn.textContent = T.copied;
            setTimeout(() => btn.textContent = T.copy, 1500);
        });
    });

    // ── Tom Select on multi-selects ─────────────────────────────────────────
    const tomSelects = [];
    document.querySelectorAll('select[data-param][multiple]').forEach(el => {
        const emptyOpt  = el.querySelector('option[value=""]');
        const placeholder = emptyOpt?.textContent.trim() ?? '—';
        emptyOpt?.remove();

        const ts = new TomSelect(el, {
            plugins: ['remove_button'],
            placeholder,
            maxOptions: null,
            onItemAdd()    { updatePreview(); },
            onItemRemove() { updatePreview(); },
        });
        tomSelects.push(ts);
    });

    document.getElementById('btn-reset').addEventListener('click', () => {
        // Reset plain inputs
        document.querySelectorAll('.qb-input:not([multiple])').forEach(el => el.value = '');
        const nameEl = document.getElementById('name-search');
        if (nameEl) nameEl.value = '';
        const refListEl = document.getElementById('ref-list');
        if (refListEl) refListEl.value = '';
        // Reset stat fields
        document.querySelectorAll('.stat-val').forEach(el => el.value = '');
        document.querySelectorAll('.stat-op').forEach(el => el.value = 'exact');
        document.querySelectorAll('.stat-chip.chip-active').forEach(c => c.classList.remove('chip-active'));
        const sortSel = document.getElementById('sort-select');
        if (sortSel) sortSel.value = '';
        // Reset Tom Select instances
        tomSelects.forEach(ts => ts.clear(true));
        document.querySelector('input[name="kwMode"][value="or"]').checked = true;
        document.querySelector('input[name="effectSlotMode"][value="or"]').checked = true;
        keywords    = [];
        effectSlots = [];
        lastMembers = [];
        currentPage = 1;
        renderTags();
        renderEffectSlots();
        updatePreview();
        document.getElementById('results-box').classList.add('hidden');
    });

    document.getElementById('btn-run').addEventListener('click', () => {
        currentPage = 1;
        document.getElementById('results-box').classList.remove('hidden');
        fetchPage(1);
    });

    // ── Name search ─────────────────────────────────────────────────────────
    document.getElementById('name-search').addEventListener('input', updatePreview);
    document.getElementById('ref-list').addEventListener('input', updatePreview);

    // Init
    // ── Debug panel ─────────────────────────────────────────────────────────
    function renderDebugPanel(resp) {
        const panel = document.getElementById('debug-panel');
        if (!panel) return; // not in dev

        const filtersHeader  = resp.headers.get('X-Debug-Filters');
        const totalHeader    = resp.headers.get('X-Debug-Total-Ms');
        const sqlMsHeader    = resp.headers.get('X-Debug-Sql-Ms');
        const sqlCountHeader = resp.headers.get('X-Debug-Sql-Count');

        if (!filtersHeader) {
            panel.classList.add('hidden');
            return;
        }

        document.getElementById('debug-total').textContent = `Total: ${totalHeader}ms`;

        const rows = document.getElementById('debug-rows');
        rows.innerHTML = '';

        filtersHeader.split(',').forEach(part => {
            const [filter, path, duration, ids] = part.split(':');
            const isFallback   = ids === '?';
            const isMeili      = path.includes('Meilisearch') || path === 'meilisearch';
            const pathLabel    = isMeili
                ? (isFallback ? '⚠ meilisearch → fallback LIKE' : '✓ meilisearch')
                : path.includes('Null') ? 'like (fallback)' : path;
            const idsLabel     = isFallback ? '— (fallback)' : Number(ids).toLocaleString();
            const durationMs   = parseInt(duration);
            const durationLabel = duration.replace('ms', '');

            const durationClass = durationMs > 1000
                ? 'text-red-600 dark:text-red-400 font-bold'
                : durationMs > 50
                    ? 'text-red-600 dark:text-red-400 font-semibold'
                    : durationMs > 15
                        ? 'text-orange-500 dark:text-orange-400'
                        : 'text-green-600 dark:text-green-400';

            rows.insertAdjacentHTML('beforeend', `
                <tr class="border-t border-yellow-200 dark:border-yellow-800">
                    <td class="pr-4 py-0.5 font-mono">${filter}</td>
                    <td class="pr-4 py-0.5">${pathLabel}</td>
                    <td class="pr-4 py-0.5 ${durationClass}">${durationLabel}ms</td>
                    <td class="py-0.5 text-gray-500 dark:text-gray-400">${idsLabel}</td>
                </tr>
            `);
        });

        // SQL row
        if (sqlMsHeader) {
            const sqlMs = parseFloat(sqlMsHeader);
            const sqlClass = sqlMs > 500 ? 'text-red-600 dark:text-red-400 font-bold'
                : sqlMs > 100 ? 'text-orange-500 dark:text-orange-400'
                : 'text-green-600 dark:text-green-400';
            rows.insertAdjacentHTML('beforeend', `
                <tr class="border-t border-yellow-200 dark:border-yellow-800">
                    <td class="pr-4 py-0.5 font-mono">SQL</td>
                    <td class="pr-4 py-0.5 text-gray-400">${sqlCountHeader} quer${sqlCountHeader === '1' ? 'y' : 'ies'}</td>
                    <td class="pr-4 py-0.5 ${sqlClass}">${sqlMs}ms</td>
                    <td class="py-0.5 text-gray-400">—</td>
                </tr>
            `);
        }

        panel.classList.remove('hidden');
    }

    setViewMode('list');
    updatePreview();
})();

// ── Lightbox ─────────────────────────────────────────────────────────────────
(function () {
    const lb    = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img');

    function open(src, alt) {
        lbImg.src = src;
        lbImg.alt = alt;
        lb.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function close() {
        lb.classList.add('hidden');
        document.body.style.overflow = '';
    }

    // Event delegation — works even after grid re-render
    document.getElementById('results-grid').addEventListener('click', e => {
        const img = e.target.closest('[data-lightbox]');
        if (img) open(img.dataset.src, img.dataset.name);
    });

    lb.addEventListener('click', close);
    document.getElementById('lightbox-img').addEventListener('click', e => e.stopPropagation());
    document.getElementById('lightbox-close').addEventListener('click', close);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
})();
</script>
</body>
</html>
