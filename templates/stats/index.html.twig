<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Stats — Altered Core</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        details[open] .chevron { transform: rotate(90deg); }
        .chevron { transition: transform 0.15s ease; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">

{# ── Header ── #}
<div class="border-b border-gray-800 bg-gray-900">
    <div class="max-w-5xl mx-auto px-6 py-10 flex items-center justify-between">
        <div>
            <a href="/" class="text-xs text-gray-500 hover:text-gray-300 transition-colors mb-2 inline-block">← Altered Core API</a>
            <h1 class="text-3xl font-bold text-white">Card Stats</h1>
            <p class="text-gray-400 mt-1 text-sm">Card groups per set, faction and rarity.</p>
        </div>
    </div>
</div>

<div class="max-w-5xl mx-auto px-6 py-10 space-y-4">

    {# ── Global rarity counters ── #}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-2">
        {% for rarityRef, rarity in globalRarities %}
        <a href="/api/cards?rarity={{ rarityRef }}" target="_blank"
           class="group flex flex-col gap-1 bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl px-5 py-4 transition-colors">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wider
                    {{ rarityRef == 'COMMON'  ? 'text-gray-400' :
                       rarityRef == 'RARE'    ? 'text-blue-400' :
                       rarityRef == 'EXALTED' ? 'text-amber-400' :
                       rarityRef == 'UNIQUE'  ? 'text-purple-400' : 'text-gray-400' }}">
                    {{ rarity.name }}
                </span>
                <svg class="w-3 h-3 text-gray-600 group-hover:text-gray-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
            </div>
            <p class="text-2xl font-bold text-white">{{ rarity.nb|number_format(0, ',', ' ') }}</p>
            <p class="text-xs text-gray-500">cards total</p>
        </a>
        {% endfor %}
    </div>

    {% set rarityColors = {
        'COMMON':  'bg-gray-700 text-gray-200',
        'RARE':    'bg-blue-900 text-blue-200',
        'UNIQUE':  'bg-purple-900 text-purple-200',
        'EXALTED': 'bg-amber-900 text-amber-200',
    } %}

    {% set factionColors = {
        'BR': 'text-red-400',
        'AX': 'text-blue-400',
        'LY': 'text-purple-400',
        'MU': 'text-green-400',
        'OR': 'text-orange-400',
        'YZ': 'text-cyan-400',
    } %}

    {% for setRef, set in sets %}
    <details class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden group" {% if loop.first %}open{% endif %}>
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer hover:bg-gray-800/50 transition-colors select-none">
            <div class="flex items-center gap-3">
                <svg class="chevron w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                <div>
                    <span class="font-semibold text-white">{{ set.name }}</span>
                    <span class="ml-2 text-xs font-mono text-gray-500 bg-gray-800 px-1.5 py-0.5 rounded">{{ set.ref }}</span>
                </div>
            </div>
            <span class="text-sm font-bold text-gray-300">{{ set.total|number_format(0, ',', ' ') }} <span class="font-normal text-gray-500 text-xs">cards</span></span>
        </summary>

        <div class="border-t border-gray-800 divide-y divide-gray-800">
            {% for factionCode, faction in set.factions %}
            <div class="px-5 py-4">
                {# Faction header #}
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                        <span class="font-mono text-sm font-bold {{ factionColors[factionCode] ?? 'text-gray-400' }}">{{ factionCode }}</span>
                        <span class="text-sm text-gray-300">{{ faction.name }}</span>
                    </div>
                    <span class="text-xs text-gray-500">{{ faction.total|number_format(0, ',', ' ') }} total</span>
                </div>

                {# Rarity breakdown #}
                <div class="flex flex-wrap gap-2 ml-10">
                    {% for rarity in faction.rarities %}
                    {% set apiUrl = '/api/cards?faction.code=' ~ factionCode ~ '&rarity=' ~ rarity.ref ~ '&set.reference=' ~ setRef %}
                    <a href="{{ apiUrl }}" target="_blank"
                       class="group/badge flex items-center gap-1.5 px-3 py-1.5 rounded-lg {{ rarityColors[rarity.ref] ?? 'bg-gray-800 text-gray-300' }} hover:ring-1 hover:ring-white/20 transition-all">
                        <span class="text-xs font-medium">{{ rarity.name }}</span>
                        <span class="text-xs font-bold opacity-80">{{ rarity.nb|number_format(0, ',', ' ') }}</span>
                        <svg class="w-2.5 h-2.5 opacity-40 group-hover/badge:opacity-80 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}

            {# Set totals by rarity #}
            {% set raritySums = {} %}
            {% for factionCode, faction in set.factions %}
                {% for rarity in faction.rarities %}
                    {% set cur = raritySums[rarity.ref] ?? {ref: rarity.ref, name: rarity.name, nb: 0} %}
                    {% set raritySums = raritySums|merge({(rarity.ref): {ref: rarity.ref, name: rarity.name, nb: cur.nb + rarity.nb}}) %}
                {% endfor %}
            {% endfor %}

            <div class="px-5 py-3 bg-gray-800/40 flex flex-wrap items-center gap-3">
                <span class="text-xs text-gray-500 uppercase tracking-wider font-medium">Set total</span>
                {% for rarityRef, rarity in raritySums %}
                {% set apiUrl = '/api/cards?rarity=' ~ rarityRef ~ '&set.reference=' ~ setRef %}
                <a href="{{ apiUrl }}" target="_blank"
                   class="group/badge flex items-center gap-1.5 px-2.5 py-1 rounded {{ rarityColors[rarityRef] ?? 'bg-gray-700 text-gray-300' }} hover:ring-1 hover:ring-white/20 transition-all">
                    <span class="text-xs font-medium">{{ rarity.name }}</span>
                    <span class="text-xs font-bold opacity-80">{{ rarity.nb|number_format(0, ',', ' ') }}</span>
                    <svg class="w-2.5 h-2.5 opacity-40 group-hover/badge:opacity-80 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                </a>
                {% endfor %}
            </div>
        </div>
    </details>
    {% endfor %}

</div>

{# Footer #}
<div class="border-t border-gray-800 mt-8">
    <div class="max-w-5xl mx-auto px-6 py-6 flex flex-wrap items-center justify-between gap-4">
        <div class="text-sm text-gray-500">Altered Core API — Community project. Not affiliated with Equinox.</div>
        <a href="/" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">Back to API →</a>
    </div>
</div>

</body>
</html>
