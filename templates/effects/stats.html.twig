<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Effect Stats — Altered Core</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        details[open] .chevron { transform: rotate(90deg); }
        .chevron { transition: transform 0.15s ease; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">

<div class="border-b border-gray-800 bg-gray-900">
    <div class="max-w-6xl mx-auto px-6 py-10">
        <a href="/" class="text-xs text-gray-500 hover:text-gray-300 transition-colors mb-2 inline-block">← Altered Core API</a>
        <div class="flex items-end justify-between gap-4 flex-wrap">
            <div>
                <h1 class="text-3xl font-bold text-white">Effect Stats</h1>
                <p class="text-gray-400 mt-1 text-sm">Distribution des effets par faction et par set.</p>
            </div>
            <a href="/stats" class="text-sm text-gray-400 hover:text-gray-200 transition-colors">Card Stats →</a>
        </div>
    </div>
</div>

{% set factionBg = {
    'BR': 'bg-red-900 text-red-200',
    'AX': 'bg-blue-900 text-blue-200',
    'LY': 'bg-purple-900 text-purple-200',
    'MU': 'bg-green-900 text-green-200',
    'OR': 'bg-orange-900 text-orange-200',
    'YZ': 'bg-cyan-900 text-cyan-200',
} %}

{% set factionText = {
    'BR': 'text-red-400',
    'AX': 'text-blue-400',
    'LY': 'text-purple-400',
    'MU': 'text-green-400',
    'OR': 'text-orange-400',
    'YZ': 'text-cyan-400',
} %}

<div class="max-w-6xl mx-auto px-6 py-10 space-y-12">

    {# ── Top 30 effects ── #}
    <section>
        <h2 class="text-lg font-semibold text-white mb-4">Top 30 effets les plus utilisés</h2>
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-800/60 text-gray-400 text-xs uppercase tracking-wider">
                    <tr>
                        <th class="px-4 py-3 text-left">#</th>
                        <th class="px-4 py-3 text-left">Effet (FR)</th>
                        <th class="px-4 py-3 text-center">Total</th>
                        <th class="px-4 py-3 text-left">Par faction</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for effect in topEffects %}
                    <tr class="hover:bg-gray-800/30 transition-colors align-top">
                        <td class="px-4 py-3 text-gray-600 text-xs font-mono">{{ loop.index }}</td>
                        <td class="px-4 py-3 max-w-xs">
                            <p class="text-gray-200 text-xs leading-relaxed line-clamp-3">
                                {{ effect.text_fr ?? effect.text_en ?? '—' }}
                            </p>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span class="text-2xl font-bold text-white">{{ effect.total }}</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex flex-wrap gap-1.5">
                                {% for code, count in effect.factions %}
                                <span class="text-xs font-mono font-bold px-2 py-0.5 rounded {{ factionBg[code] ?? 'bg-gray-700 text-gray-300' }}">
                                    {{ code }} <span class="opacity-75">{{ count }}</span>
                                </span>
                                {% endfor %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    {# ── Per set ── #}
    <section>
        <h2 class="text-lg font-semibold text-white mb-4">Effets par set</h2>
        <div class="space-y-3">
        {% for setRef, set in sets %}
        <details class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden" {% if loop.first %}open{% endif %}>
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer hover:bg-gray-800/50 transition-colors select-none">
                <div class="flex items-center gap-3">
                    <svg class="chevron w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span class="font-semibold text-white">{{ set.name }}</span>
                    <span class="text-xs font-mono text-gray-500 bg-gray-800 px-1.5 py-0.5 rounded">{{ set.ref }}</span>
                </div>
                <span class="text-sm font-bold text-gray-300">{{ set.effects|length }} <span class="font-normal text-gray-500 text-xs">effets distincts</span></span>
            </summary>

            <div class="border-t border-gray-800 overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-800/60 text-gray-400 text-xs uppercase tracking-wider">
                        <tr>
                            <th class="px-4 py-2 text-left">Effet (FR)</th>
                            <th class="px-4 py-2 text-center">Total</th>
                            <th class="px-4 py-2 text-left">Par faction</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/60">
                        {% for effect in set.effects %}
                        <tr class="hover:bg-gray-800/20 transition-colors align-top">
                            <td class="px-4 py-2 max-w-sm">
                                <p class="text-gray-200 text-xs leading-relaxed line-clamp-3">
                                    {{ effect.text_fr ?? effect.text_en ?? '—' }}
                                </p>
                            </td>
                            <td class="px-4 py-2 text-center">
                                <span class="text-lg font-bold text-white">{{ effect.total }}</span>
                            </td>
                            <td class="px-4 py-2">
                                <div class="flex flex-wrap gap-1">
                                    {% for code, count in effect.factions %}
                                    <span class="text-xs font-mono font-bold px-2 py-0.5 rounded {{ factionBg[code] ?? 'bg-gray-700 text-gray-300' }}">
                                        {{ code }} <span class="opacity-75">{{ count }}</span>
                                    </span>
                                    {% endfor %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </details>
        {% endfor %}
        </div>
    </section>

</div>

<div class="border-t border-gray-800 mt-8">
    <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-center justify-between gap-4">
        <div class="text-sm text-gray-500">Altered Core API — Community project. Not affiliated with Equinox.</div>
        <a href="/" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">Back to API →</a>
    </div>
</div>

</body>
</html>
